NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173
TRUST_PROXY=1

MONGODB_URI=mongodb://localhost:27017/diro
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# Instagram Graph fetch for reel metrics
INSTAGRAM_GRAPH_ENABLED=true
INSTAGRAM_GRAPH_DOC_ID=8845758582119845
INSTAGRAM_GRAPH_CACHE_TTL_MS=600000
INSTAGRAM_GRAPH_REQUEST_TIMEOUT_MS=12000
INSTAGRAM_GRAPH_COOKIES_FILE=./cookies.json

# YouTube Shorts/video fetch via YouTube Data API
YOUTUBE_SR_ENABLED=true
YOUTUBE_SR_CACHE_TTL_MS=600000
YOUTUBE_DATA_API_KEY=

# Global external metrics rate limiting
# 100 requests per 20 minutes (recommended default for a single IP)
EXTERNAL_METRICS_WINDOW_MS=1200000
EXTERNAL_METRICS_MAX_REQUESTS_PER_WINDOW=100

# On-demand cap (list/get clip endpoints)
# 5 requests per minute (recommended default for a single IP)
EXTERNAL_METRICS_ON_DEMAND_WINDOW_MS=60000
EXTERNAL_METRICS_ON_DEMAND_MAX_REQUESTS_PER_WINDOW=5

# Refresh fan-out limits
EXTERNAL_METRICS_ON_DEMAND_CLIP_LIMIT=5
EXTERNAL_METRICS_SCHEDULER_BATCH_SIZE=50
EXTERNAL_METRICS_MAX_CONCURRENT_REFRESHES=1
EXTERNAL_METRICS_FAILURE_COOLDOWN_MS=30000

# Payment simulation behavior (no external processor required)
PAYMENTS_AUTO_COMPLETE=true

# Background jobs
BACKGROUND_JOBS_ENABLED=true
CLIP_REFRESH_INTERVAL_MS=600000

# Required for brand logo uploads (Cloudinary)
CLOUD_NAME=
CLOUD_API_KEY=
CLOUD_API_SECRET=

# local (default) or cloudinary
UPLOAD_STORAGE=local
